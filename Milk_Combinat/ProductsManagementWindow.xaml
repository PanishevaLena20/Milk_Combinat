<Window x:Class="Milk_Combinat.ProductsManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Milk_Combinat"
        mc:Ignorable="d"
        Title="ProductsManagementWindow" Height="450" Width="800">
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="60" Background="#27AE60">
                <TextBlock Text="Управление товарами" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ListBox x:Name="lstProducts" Grid.Row="1" Margin="10">
                <ListBoxItem>1. Молоко цельное 1л - 89.99 ₽</ListBoxItem>
                <ListBoxItem>2. Хлеб белый 300г - 49.99 ₽</ListBoxItem>
                <ListBoxItem>3. Сыр Российский 200г - 159.99 ₽</ListBoxItem>
                <ListBoxItem>4. Яблоки 1кг - 99.99 ₽</ListBoxItem>
                <ListBoxItem>5. Чипсы 150г - 119.99 ₽</ListBoxItem>
                <ListBoxItem>6. Кока-Кола 1.5л - 129.99 ₽</ListBoxItem>
            </ListBox>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button x:Name="btnAdd" Content="Добавить" Width="100" Height="35" Margin="5" Click="btnAdd_Click_1"/>
                <Button x:Name="btnEdit" Content="Редактировать" Width="100" Height="35" Margin="5" Click="btnEdit_Click_1"/>
                <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="35" Margin="5" Click="btnDelete_Click_1"/>
                <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Click="btnClose_Click_1"/>
            </StackPanel>
        </Grid>
</Window>

