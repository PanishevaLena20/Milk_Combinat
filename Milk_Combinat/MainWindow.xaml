<Window x:Class="Milk_Combinat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Milk_Combinat"
        mc:Ignorable="d"
        Title="MainWindow" Height="498" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Транспортная компания" 
                   FontSize="22" FontWeight="Bold" Foreground="#2C3E50" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,5">
            <TextBlock Text="Логин" FontSize="14" Foreground="#555"/>
            <TextBox x:Name="txtLogin" FontSize="14" Height="35" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,15,0,5">
            <TextBlock Text="Пароль" FontSize="14" Foreground="#555"/>
            <PasswordBox x:Name="txtPassword" FontSize="14" Height="35" Margin="0,5,0,0"/>
        </StackPanel>

        <Button Grid.Row="3" x:Name="btnLogin" Content="🔓 Войти" 
                Width="120" Height="40" Margin="0,15,0,0"
                Background="#3498DB" Foreground="White" FontWeight="Bold"
                Click="BtnLogin_Click" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="4" x:Name="lblError" Foreground="Red" 
                   TextAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>

        <TextBlock Grid.Row="5" Text="Тестовые: admin / 123   |   user / 123" 
                   FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,15,0,0"/>
    </Grid>
</Window>




