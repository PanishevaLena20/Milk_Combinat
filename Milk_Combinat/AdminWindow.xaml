<Window x:Class="Milk_Combinat.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Milk_Combinat"
        mc:Ignorable="d"
        Title="AdminWindow" Height="450" Width="800">
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="80" Background="#3498DB">
                <StackPanel VerticalAlignment="Center" Margin="15">
                    <TextBlock Text="Панель администратора" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Margin="20">
                <StackPanel>
                    <TextBlock x:Name="lblWelcome" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,20"/>
                    <Button x:Name="btnManageUsers" Content="Управление пользователями" Width="250" Height="50" Margin="0,10" Click="btnManageUsers_Click_1"/>
                    <Button x:Name="btnManageProducts" Content="Управление товарами" Width="250" Height="50" Margin="0,10" Click="btnManageProducts_Click_1"/>
                    <Button x:Name="btnViewOrders" Content="Просмотр заказов" Width="250" Height="50" Margin="0,10" Click="btnViewOrders_Click_1"/>
                    <Button x:Name="btnExit" Content="Выход" Width="250" Height="50" Margin="0,20" Background="#E74C3C" Foreground="White" Click="btnExit_Click_1"/>
                </StackPanel>
            </Border>
        </Grid>
</Window>

