<Window x:Class="Milk_Combinat.UsersManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Milk_Combinat"
        mc:Ignorable="d"
        Title="UsersManagementWindow" Height="450" Width="800">
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="60" Background="#3498DB">
                <TextBlock Text="Управление пользователями" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ListBox x:Name="lstUsers" Grid.Row="1" Margin="10">
                <ListBoxItem>1. Иван Петров (Администратор)</ListBoxItem>
                <ListBoxItem>2. Елена Соколова (Администратор)</ListBoxItem>
                <ListBoxItem>3. Дмитрий Кузнецов (Менеджер)</ListBoxItem>
                <ListBoxItem>4. Анна Морозова (Менеджер)</ListBoxItem>
                <ListBoxItem>5. Алексей Сидоров (Пользователь)</ListBoxItem>
                <ListBoxItem>6. Ольга Лебедева (Пользователь)</ListBoxItem>
            </ListBox>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button x:Name="btnAdd" Content="Добавить" Width="100" Height="35" Margin="5" Click="btnAdd_Click_1"/>
                <Button x:Name="btnEdit" Content="Редактировать" Width="100" Height="35" Margin="5" Click="btnEdit_Click_1"/>
                <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="35" Margin="5" Click="btnDelete_Click_1"/>
                <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5" Background="#E74C3C" Foreground="White" Click="btnClose_Click_1"/>
            </StackPanel>
        </Grid>
</Window>

